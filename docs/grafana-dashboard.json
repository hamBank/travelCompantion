{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "version": "" },
    { "type": "panel", "id": "timeseries", "version": "" },
    { "type": "panel", "id": "barchart", "version": "" },
    { "type": "panel", "id": "bargauge", "version": "" }
  ],
  "title": "Travel Companion",
  "uid": "travelcomp-v1",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["travelcomp"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "constant",
        "current": { "value": "travelcomp" },
        "hide": 2
      }
    ]
  },
  "panels": [

    { "type": "row", "title": "Overview", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "id": 1, "collapsed": false },

    {
      "id": 2, "title": "Req / min", "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"travelcomp\"}[5m])) * 60", "legendFormat": "req/min", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    {
      "id": 3, "title": "Error rate", "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"travelcomp\",status=~\"4xx|5xx\"}[5m])) / sum(rate(http_requests_total{job=\"travelcomp\"}[5m]))", "legendFormat": "error %", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    {
      "id": 4, "title": "Claude spend — 24 h", "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.50 }, { "color": "red", "value": 2.00 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "increase(travelcomp_claude_cost_dollars_total{job=\"travelcomp\"}[24h])", "legendFormat": "USD", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    {
      "id": 5, "title": "Imports parsed — 24 h", "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "increase(travelcomp_email_ingested_total{job=\"travelcomp\",status=\"parsed\"}[24h])", "legendFormat": "parsed", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    {
      "id": 6, "title": "Pending applied — 24 h", "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "increase(travelcomp_pending_decided_total{job=\"travelcomp\",decision=\"applied\"}[24h])", "legendFormat": "applied", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    {
      "id": 7, "title": "Claude avg cost / request — 24 h", "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.20 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "rate(travelcomp_claude_cost_per_request_dollars_sum{job=\"travelcomp\"}[24h]) / rate(travelcomp_claude_cost_per_request_dollars_count{job=\"travelcomp\"}[24h])", "legendFormat": "avg USD", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },

    { "type": "row", "title": "HTTP", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "id": 10, "collapsed": false },

    {
      "id": 11, "title": "Request rate by status", "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total{job=\"travelcomp\"}[5m]))", "legendFormat": "{{status}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 12, "title": "p95 latency by endpoint", "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"travelcomp\"}[5m])))", "legendFormat": "p95 {{handler}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    { "type": "row", "title": "Claude AI", "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }, "id": 20, "collapsed": false },

    {
      "id": 21, "title": "Claude spend ($/hr)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(travelcomp_claude_cost_dollars_total{job=\"travelcomp\"}[1h]) * 3600", "legendFormat": "USD/hr", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 22, "title": "Token burn (tokens/min)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (type) (rate(travelcomp_claude_tokens_total{job=\"travelcomp\"}[5m]) * 60)", "legendFormat": "{{type}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 23, "title": "Claude request duration", "type": "timeseries",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(travelcomp_claude_duration_seconds_bucket{job=\"travelcomp\"}[10m]))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "histogram_quantile(0.95, rate(travelcomp_claude_duration_seconds_bucket{job=\"travelcomp\"}[10m]))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "histogram_quantile(0.99, rate(travelcomp_claude_duration_seconds_bucket{job=\"travelcomp\"}[10m]))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 24, "title": "Cost per request distribution", "type": "bargauge",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" },
      "targets": [
        { "expr": "sum by (le) (increase(travelcomp_claude_cost_per_request_dollars_bucket{job=\"travelcomp\"}[24h]))", "legendFormat": "≤${{le}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 25, "title": "Claude success / error", "type": "bargauge",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "lcd" },
      "targets": [
        { "expr": "increase(travelcomp_claude_requests_total{job=\"travelcomp\"}[24h])", "legendFormat": "{{status}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    { "type": "row", "title": "Import Pipeline", "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }, "id": 30, "collapsed": false },

    {
      "id": 31, "title": "Email ingest rate", "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (status) (increase(travelcomp_email_ingested_total{job=\"travelcomp\"}[1h]))", "legendFormat": "{{status}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 32, "title": "Pending changes created — 24 h", "type": "barchart",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "xField": "kind", "barWidth": 0.7, "groupWidth": 0.7, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (kind, op) (increase(travelcomp_pending_changes_total{job=\"travelcomp\"}[24h]))", "legendFormat": "{{op}} / {{kind}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 33, "title": "Pending decisions — 24 h", "type": "bargauge",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": [{ "matcher": { "id": "byName", "options": "discarded" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "lcd" },
      "targets": [
        { "expr": "increase(travelcomp_pending_decided_total{job=\"travelcomp\"}[24h])", "legendFormat": "{{decision}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    { "type": "row", "title": "External APIs", "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 }, "id": 40, "collapsed": false },

    {
      "id": 41, "title": "Request rate by service", "type": "timeseries",
      "gridPos": { "x": 0, "y": 36, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (service) (rate(travelcomp_external_requests_total{job=\"travelcomp\"}[5m]))", "legendFormat": "{{service}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 42, "title": "Error rate by service", "type": "timeseries",
      "gridPos": { "x": 8, "y": 36, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (service) (rate(travelcomp_external_requests_total{job=\"travelcomp\",status=\"error\"}[5m])) / sum by (service) (rate(travelcomp_external_requests_total{job=\"travelcomp\"}[5m]))", "legendFormat": "{{service}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },

    {
      "id": 43, "title": "Calls by service — 24 h", "type": "barchart",
      "gridPos": { "x": 16, "y": 36, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }]
      },
      "options": { "xField": "service", "barWidth": 0.7, "groupWidth": 0.7, "stacking": "normal", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (service, status) (increase(travelcomp_external_requests_total{job=\"travelcomp\"}[24h]))", "legendFormat": "{{status}} / {{service}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    }

  ]
}
