# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to a local SQLite file when unset. For Postgres, provision with
# scripts/provision_postgres.sh and set (note the +psycopg driver):
# DATABASE_URL=postgresql+psycopg://travelcomp:password@localhost/travelcomp

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (type: Web application)
# 4. Add Authorised JavaScript origins:
#      http://localhost:8000   (local dev via built frontend)
#      http://localhost:5173   (local dev via Vite dev server)
#      https://your-domain.com (production)
# 5. Copy the Client ID into both vars below.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Only this email address can sign in. Leave blank to allow any Google account.
ALLOWED_EMAIL=you@gmail.com

# Random secret used to sign session JWTs — change this before deploying.
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session lasts (days). Default: 30.
# JWT_EXPIRE_DAYS=30

# ── Google Maps / Places ──────────────────────────────────────────────────────
# Places API key — used for the "Auto-fill" enrichment (address/phone/website).
# GOOGLE_PLACES_API_KEY=your-places-api-key

# Routes API key — used for "Calculate distance" (road/path distance + duration).
# Needs the Routes API enabled on this key. Falls back to GOOGLE_PLACES_API_KEY
# if left unset.
# GOOGLE_ROUTE_API_KEY=your-routes-api-key

# ── Email ingestion (forward bookings to import+<token>@your-domain) ───────────
# Shared secret between postfix's mail_ingest.py pipe and POST /ingest/email.
# Must match on both sides. Generate with: openssl rand -hex 32
# MAIL_INGEST_SECRET=
# Domain used to build each user's forwarding address (import+<token>@MAIL_DOMAIN).
# MAIL_DOMAIN=tripplan.hups.club
# Where raw emails + attachments are stored (default: <app>/mail_store).
# MAIL_STORE_DIR=/opt/travelcomp/mail_store
