# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (type: Web application)
# 4. Add Authorised JavaScript origins:
#      http://localhost:8000   (local dev via built frontend)
#      http://localhost:5173   (local dev via Vite dev server)
#      https://your-domain.com (production)
# 5. Copy the Client ID into both vars below.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Only this email address can sign in. Leave blank to allow any Google account.
ALLOWED_EMAIL=you@gmail.com

# Random secret used to sign session JWTs — change this before deploying.
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session lasts (days). Default: 30.
# JWT_EXPIRE_DAYS=30
